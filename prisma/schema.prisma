generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model bitacora_auditoria {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id           String?   @db.Uuid
  accion               String    @db.VarChar(100)
  tabla_afectada       String?   @db.VarChar(50)
  registro_afectado_id String?   @db.Uuid
  valores_anteriores   Json?
  valores_nuevos       Json?
  direccion_ip         String?   @db.Inet
  user_agent           String?
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  usuario              usuario?  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_bitacora_fecha")
  @@index([usuario_id], map: "idx_bitacora_usuario")
}

model habitacion {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id            String                @db.Uuid
  numero              String                @db.VarChar(10)
  nombre              String?               @db.VarChar(100)
  tipo_habitacion     tipo_habitacion_enum
  descripcion_corta   String?
  descripcion_larga   String?
  precio_base_noche   Decimal               @db.Decimal(10, 2)
  capacidad_maxima    Int                   @db.SmallInt
  numero_camas        Int                   @db.SmallInt
  tipo_camas          String?               @db.VarChar(50)
  metros_cuadrados    Int?                  @db.SmallInt
  estatus             String?               @default("disponible") @db.VarChar(20)
  atributos_extra     Json?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?             @db.Timestamptz(6)
  hotel               hotel                 @relation(fields: [hotel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  habitacion_servicio habitacion_servicio[]
  reservacion         reservacion[]

  @@unique([hotel_id, numero])
  @@index([estatus], map: "idx_habitacion_estatus")
  @@index([hotel_id], map: "idx_habitacion_hotel")
}

model habitacion_servicio {
  habitacion_id String     @db.Uuid
  servicio_id   String     @db.Uuid
  habitacion    habitacion @relation(fields: [habitacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  servicio      servicio   @relation(fields: [servicio_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([habitacion_id, servicio_id])
}

model hotel {
  id                   String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre               String          @db.VarChar(150)
  descripcion_corta    String?
  descripcion_larga    String?
  direccion            String
  latitud              Decimal?        @db.Decimal(10, 8)
  longitud             Decimal?        @db.Decimal(11, 8)
  telefono             String?         @db.VarChar(20)
  email_contacto       String          @db.VarChar(100)
  politica_cancelacion String?
  estatus              String?         @default("activo") @db.VarChar(20)
  created_at           DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?       @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?       @db.Timestamptz(6)
  habitacion           habitacion[]
  promocion            promocion[]
  sitio_cercano        sitio_cercano[]
  usuario              usuario[]
}

model huesped {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre              String                @db.VarChar(80)
  apellidos           String                @db.VarChar(120)
  email               String?               @db.VarChar(100)
  telefono            String                @db.VarChar(20)
  fecha_nacimiento    DateTime?             @db.Date
  nacionalidad        String?               @db.VarChar(60)
  tipo_documento      String?               @db.VarChar(20)
  numero_documento    String?               @unique @db.VarChar(30)
  direccion           String?
  ciudad              String?               @db.VarChar(60)
  pais                String?               @db.VarChar(60)
  huesped_reservacion huesped_reservacion[]
}

model huesped_reservacion {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reservacion_id String      @db.Uuid
  huesped_id     String      @db.Uuid
  es_principal   Boolean?    @default(false)
  huesped        huesped     @relation(fields: [huesped_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservacion    reservacion @relation(fields: [reservacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([reservacion_id, huesped_id])
}

model itinerario {
  id                  String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fecha_creacion      DateTime?     @default(now()) @db.Timestamptz(6)
  fecha_actualizacion DateTime?     @default(now()) @db.Timestamptz(6)
  nombre              String        @db.VarChar(100)
  horario_inicio      DateTime      @db.Time(6)
  horario_fin         DateTime      @db.Time(6)
  disponibilidad      Int           @default(1)
  seleccionado        Boolean       @default(false)
  usuario_id          String        @db.Uuid
  reservacion_id      String?       @db.Uuid
  sitio_cercano_id    String        @db.Uuid
  reservacion         reservacion?  @relation(fields: [reservacion_id], references: [id], onUpdate: NoAction, map: "fk_itinerario_reservacion")
  sitio_cercano       sitio_cercano @relation(fields: [sitio_cercano_id], references: [id], onUpdate: NoAction, map: "fk_itinerario_sitio_cercano")
  usuario             usuario       @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_itinerario_usuario")

  @@index([reservacion_id], map: "idx_itinerario_reservacion")
  @@index([sitio_cercano_id], map: "idx_itinerario_sitio_cercano")
  @@index([usuario_id], map: "idx_itinerario_usuario")
}

model pago {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reservacion_id      String           @db.Uuid
  monto               Decimal          @db.Decimal(10, 2)
  impuestos           Decimal?         @db.Decimal(10, 2)
  descuento           Decimal?         @default(0) @db.Decimal(10, 2)
  metodo_pago         metodo_pago_enum
  estado              estado_pago_enum @default(pendiente)
  referencia_bancaria String?          @db.VarChar(100)
  folio_transaccion   String?          @unique @db.VarChar(100)
  fecha_pago          DateTime?        @default(now()) @db.Timestamptz(6)
  metadata            Json?
  reservacion         reservacion      @relation(fields: [reservacion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([reservacion_id], map: "idx_pago_reservacion")
}

model permiso {
  id      String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre  String  @unique @db.VarChar(100)
  recurso String? @db.VarChar(50)
}

model promocion {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id        String    @db.Uuid
  nombre          String    @db.VarChar(150)
  descripcion     String?
  tipo_descuento  String?   @db.VarChar(20)
  valor_descuento Decimal   @db.Decimal(10, 2)
  fecha_inicio    DateTime  @db.Date
  fecha_fin       DateTime  @db.Date
  activo          Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  hotel           hotel     @relation(fields: [hotel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model reservacion {
  id                  String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  folio               String                  @unique @db.VarChar(15)
  habitacion_id       String                  @db.Uuid
  usuario_id          String?                 @db.Uuid
  fecha_entrada       DateTime                @db.Date
  fecha_salida        DateTime                @db.Date
  cantidad_huespedes  Int                     @db.SmallInt
  estado              estado_reservacion_enum @default(pendiente)
  comentarios         String?
  precio_total_noches Decimal                 @db.Decimal(10, 2)
  impuestos           Decimal?                @db.Decimal(10, 2)
  descuento_aplicado  Decimal?                @default(0) @db.Decimal(10, 2)
  total_pagar         Decimal                 @db.Decimal(10, 2)
  created_at          DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?               @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?               @db.Timestamptz(6)
  huesped_reservacion huesped_reservacion[]
  itinerario          itinerario[]
  pago                pago[]
  habitacion          habitacion              @relation(fields: [habitacion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([estado], map: "idx_reservacion_estado")
  @@index([fecha_entrada, fecha_salida], map: "idx_reservacion_fechas")
  @@index([usuario_id], map: "idx_reservacion_usuario")
}

model rol {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String  @unique @db.VarChar(50)
  descripcion String?
  usuario     usuario[]
}

model servicio {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre              String                @unique @db.VarChar(80)
  icono               String?               @db.VarChar(50)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  habitacion_servicio habitacion_servicio[]
}

model sitio_cercano {
  id                      String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id                String       @db.Uuid
  nombre                  String       @db.VarChar(150)
  categoria               String       @db.VarChar(50)
  direccion               String?
  latitud                 Decimal      @db.Decimal(10, 8)
  longitud                Decimal      @db.Decimal(11, 8)
  distancia_km            Decimal?     @db.Decimal(6, 2)
  tiempo_estimado_minutos Int?         @db.SmallInt
  telefono                String?      @db.VarChar(20)
  sitio_web               String?      @db.VarChar(200)
  horario                 String?
  calificacion            Decimal?     @db.Decimal(2, 1)
  created_at              DateTime?    @default(now()) @db.Timestamptz(6)
  itinerario              itinerario[]
  hotel                   hotel        @relation(fields: [hotel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([categoria], map: "idx_sitio_cercano_categoria")
}

model usuario {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre             String               @db.VarChar(80)
  apellidos          String               @db.VarChar(120)
  email              String               @unique @db.VarChar(100)
  password_hash      String
  telefono           String?              @db.VarChar(20)
  foto_url           String?
  estatus            Boolean?             @default(true)
  ultima_conexion    DateTime?            @db.Timestamptz(6)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?            @db.Timestamptz(6)
  hotel_id           String?              @db.Uuid
  rol_id             String?              @db.Uuid
  bitacora_auditoria bitacora_auditoria[]
  itinerario         itinerario[]
  hotel              hotel?               @relation(fields: [hotel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rol                rol?                 @relation(fields: [rol_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@index([email], map: "idx_usuario_email", where: raw("(deleted_at IS NULL)"))
}

enum estado_pago_enum {
  pendiente
  pagado
  reembolsado
  fallido
}

enum estado_reservacion_enum {
  pendiente
  confirmada
  activa
  finalizada
  cancelada
}

enum metodo_pago_enum {
  tarjeta_credito
  tarjeta_debito
  paypal
  transferencia
  efectivo
}

enum tipo_habitacion_enum {
  individual
  doble
}
