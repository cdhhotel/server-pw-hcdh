datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model bitacora_auditoria {
  id                 String   @id @default(uuid())
  usuario_id         String?
  accion             String   @db.VarChar(100)
  tabla_afectada     String?  @db.VarChar(50)
  registro_afectado_id String?
  valores_anteriores Json?
  valores_nuevos     Json?
  direccion_ip       String?  @db.Inet
  user_agent         String?
  created_at         DateTime @default(now())
}

model habitacion {
  id                    String   @id @default(uuid())
  hotel_id              String
  numero                String   @db.VarChar(10)
  nombre                String?  @db.VarChar(100)
  tipo_habitacion       String
  descripcion_corta     String?
  descripcion_larga     String?
  precio_base_noche     Decimal  @db.Decimal(10, 2)
  capacidad_maxima      Int
  numero_camas          Int
  tipo_camas            String?  @db.VarChar(50)
  metros_cuadrados      Int?
  estatus               String?  @db.VarChar(20) @default("disponible")
  atributos_extra       Json?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
  deleted_at            DateTime?
  @@unique([hotel_id, numero])
}

model habitacion_servicio {
  habitacion_id String
  servicio_id   String
  @@id([habitacion_id, servicio_id])
}

model hotel {
  id            String   @id @default(uuid())
  nombre        String   @db.VarChar(150)
  descripcion_corta String?
  descripcion_larga String?
  direccion     String
  latitud       Decimal? @db.Decimal(10, 8)
  longitud      Decimal? @db.Decimal(11, 8)
  telefono      String?  @db.VarChar(20)
  email_contacto String  @db.VarChar(100)
  politica_cancelacion String?
  estatus       String?  @db.VarChar(20) @default("activo")
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
  deleted_at    DateTime?
}

model huesped {
  id              String @id @default(uuid())
  nombre          String @db.VarChar(80)
  apellidos       String @db.VarChar(120)
  email           String? @db.VarChar(100)
  telefono        String @db.VarChar(20)
  fecha_nacimiento DateTime?
  nacionalidad    String? @db.VarChar(60)
  tipo_documento  String? @db.VarChar(20)
  numero_documento String? @db.VarChar(30)
  direccion       String?
  ciudad          String? @db.VarChar(60)
  pais            String? @db.VarChar(60)
  @@unique([numero_documento])
}

model huesped_reservacion {
  id           String @id @default(uuid())
  reservacion_id String
  huesped_id   String
  es_principal Boolean @default(false)
  @@unique([reservacion_id, huesped_id])
}

model itinerario {
  id                   String @id @default(uuid())
  fecha_creacion       DateTime @default(now())
  fecha_actualizacion  DateTime @default(now())
  nombre               String @db.VarChar(100)
  horario_inicio       String
  horario_fin          String
  disponibilidad       Int @default(1)
  seleccionado         Boolean @default(false)
  usuario_id           String
  reservacion_id       String?
  sitio_cercano_id     String
}

model pago {
  id                 String   @id @default(uuid())
  reservacion_id     String
  monto              Decimal  @db.Decimal(10, 2)
  impuestos          Decimal? @db.Decimal(10, 2)
  descuento          Decimal? @db.Decimal(10, 2) @default("0")
  metodo_pago        String
  estado             String   @default("pendiente")
  referencia_bancaria String?
  folio_transaccion  String?  @db.VarChar(100)
  fecha_pago         DateTime? @default(now())
  metadata           Json?
  @@unique([folio_transaccion])
}

model permiso {
  id    String @id @default(uuid())
  nombre String @db.VarChar(100) @unique
  recurso String? @db.VarChar(50)
}

model promocion {
  id         String @id @default(uuid())
  hotel_id   String
  nombre     String @db.VarChar(150)
  descripcion String?
  tipo_descuento String?
  valor_descuento Decimal @db.Decimal(10, 2)
  fecha_inicio DateTime
  fecha_fin   DateTime
  activo      Boolean @default(true)
  created_at  DateTime @default(now())
}

model reservacion {
  id                   String @id @default(uuid())
  folio                String @db.VarChar(15) @unique
  habitacion_id        String
  usuario_id           String
  fecha_entrada        DateTime
  fecha_salida         DateTime
  cantidad_huespedes   Int
  estado               String @default("pendiente")
  comentarios          String?
  precio_total_noches  Decimal @db.Decimal(10, 2)
  impuestos            Decimal?
  descuento_aplicado   Decimal? @db.Decimal(10, 2) @default("0")
  total_pagar          Decimal @db.Decimal(10, 2)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now())
  deleted_at           DateTime?
}

model rol {
  id    String @id @default(uuid())
  nombre String @db.VarChar(50) @unique
  descripcion String?
}

model rol_permiso {
  rol_id String
  permiso_id String
  @@id([rol_id, permiso_id])
}

model servicio {
  id    String @id @default(uuid())
  nombre String @db.VarChar(80) @unique
  icono  String? @db.VarChar(50)
  created_at DateTime @default(now())
}

model sitio_cercano {
  id    String @id @default(uuid())
  hotel_id String
  nombre String @db.VarChar(150)
  categoria String @db.VarChar(50)
  direccion String?
  latitud Decimal @db.Decimal(10, 8)
  longitud Decimal @db.Decimal(11, 8)
  distancia_km Decimal?
  tiempo_estimado_minutos Int?
  telefono String? @db.VarChar(20)
  sitio_web String? @db.VarChar(200)
  horario String?
  calificacion Decimal?
  created_at DateTime @default(now())
}

model usuario {
  id String @id @default(uuid())
  hotel_id String?
  nombre String @db.VarChar(80)
  apellidos String @db.VarChar(120)
  email String @db.VarChar(100) @unique
  password_hash String
  telefono String? @db.VarChar(20)
  foto_url String?
  estatus Boolean? @default(true)
  ultima_conexion DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  deleted_at DateTime?
}

model usuario_rol {
  usuario_id String
  rol_id String
  @@id([usuario_id, rol_id])
}
